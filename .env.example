# Local-only convenience for running/testing outside Cloud Run. In
# production these are set as Cloud Function environment variables (via
# `gcloud functions deploy --set-env-vars=...`), not a committed .env.
#
# Nothing below is a secret. The one credential this app needs (the
# TikTok OAuth access token) is NEVER an env var -- it lives in Secret
# Manager, and only its secret ID (a name, not a value) is configured here.

# GCP project that holds the Secret Manager secret and Cloud Tasks queue.
GCP_PROJECT_ID=your-gcp-project-id

# Your TikTok Developer app's client key. Not secret -- an app
# identifier, not a credential (the client SECRET and the user's access
# token are the actual credentials, and neither is an env var here).
TIKTOK_CLIENT_KEY=aw_your_client_key

# The Secret Manager secret ID (not the value) holding the shared
# credentials JSON blob (see GCP-Builds/06-api-keymaster). This build's
# TikTok OAuth access token lives at the "tiktok_access_token" key inside
# that blob. Defaults to "app-credentials" if unset.
CREDENTIALS_SECRET_ID=app-credentials

# Which key inside the shared credentials blob holds this build's TikTok
# access token. Defaults to "tiktok_access_token" if unset.
TIKTOK_CREDENTIAL_KEY=tiktok_access_token

# Cloud Tasks queue Dispatch enqueues into, and its region.
CLOUD_TASKS_QUEUE=publish-posts
CLOUD_TASKS_LOCATION=us-central1

# The deployed URL of the Publish function -- Dispatch targets this when
# creating each Cloud Task. Only known after Publish is first deployed.
PUBLISH_FUNCTION_URL=https://publish-xxxxxxxxxx-uc.a.run.app

# Service account email Cloud Tasks uses to mint an OIDC token when
# calling Publish (which requires authentication). Not secret -- an
# identifier, not a credential.
TASKS_INVOKER_SERVICE_ACCOUNT_EMAIL=tiktok-poster-invoker@your-gcp-project-id.iam.gserviceaccount.com
